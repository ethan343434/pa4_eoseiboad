<!DOCTYPE html>
<html lang="en">

<head>
    <title>Favorite Movies</title>
    
    <link rel="stylesheet" href="bootstrap-4.1.3-dist/css/bootstrap.min.css">
   
    <link rel="stylesheet" href="fontawesome-free-5.5.0-web/css/all.min.css">
    <link rel="stylesheet" href="styles.css">
</head>

<body>
    <header>
        <nav class="navbar navbar-dark bg-dark">
            <a class="navbar-brand" href="index.html">Ethan Boadu</a>
            <ul class="nav nav-pills">
                <li class="nav-item"><a class="nav-link " href="index.html"><i class="fas fa-info-circle"></i> Activities</a></li>

                <li class="nav-item"><a class="nav-link" href="home.html"><i class="fas fa-home"></i> Home Page</a></li>
                <li class="nav-item"><a class="nav-link" href="life.html"><i class="fas fa-user"></i> My Life</a></li>
                <li class="nav-item"><a class="nav-link active" href="movies.html"><i class="fas fa-film"></i> Favorite Movies</a></li>
                <li class="nav-item"><a class="nav-link" href="foods.html"><i class="fas fa-utensils"></i> Favorite Foods</a></li>
            </ul>
        </nav>
    </header>

    <div class="container mt-4">
        <div class="alert alert-success text-center" role="alert">
            Welcome to my Favorite Movies page! Here are some of the films I enjoy the most.
        </div>
        <h1 class="text-center mb-4">My Favorite Movies</h1>
        <p class="text-center mb-5">These are some of my favorite movies that I love watching in my free time.</p>
        
        
        <div class="row justify-content-center">
            
            <div class="col-md-5 col-lg-3 mb-4">
                <div class="card h-100 shadow-sm movie-card">
                <%= image_tag "Avengers.jpg", class: "card-img-top", alt: "Avengers" %>
                    <div class="card-body">
                        <h5 class="card-title">Avengers</h5>
                        <p class="card-text">I love Avengers because I enjoy watching superheroes fight!</p>
                    </div>
                </div>
            </div>

           
            <div class="col-md-5 col-lg-3 mb-4">
                <div class="card h-100 shadow-sm movie-card">
                <%= image_tag "Final Destinantion 5.jpg", class: "card-img-top", alt: "Final Destinantion 5" %>
                    <div class="card-body">
                        <h5 class="card-title">Final Destination 5</h5>
                        <p class="card-text">Final Destination 5 is thrilling because of the way the main character tries to escape fate!</p>
                    </div>
                </div>
            </div>

            
            <div class="col-md-5 col-lg-3 mb-4">
                <div class="card h-100 shadow-sm movie-card">
                <%= image_tag "Hancock.jpg", class: "card-img-top", alt: "Hancock" %>
                    <div class="card-body">
                        <h5 class="card-title">Hancock</h5>
                        <p class="card-text">Hancock is a unique take on superheroes, and I enjoy Will Smith's performance.</p>
                    </div>
                </div>
            </div>

            
            <div class="col-md-5 col-lg-3 mb-4">
                <div class="card h-100 shadow-sm movie-card">
                <%= image_tag "Rush Hour.jpg", class: "card-img-top", alt: "Rush Hour" %>
                    <div class="card-body">
                        <h5 class="card-title">Rush Hour</h5>
                        <p class="card-text">Rush Hour is one of my favorites because of the humor and action-packed scenes.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    
    <div class="text-center mt-4 mb-5">
        <a class="btn btn-primary btn-lg" href="index.html">
            <i class="fas fa-arrow-left"></i> Back to Index
        </a>
    </div>

    
    <footer class="footer text-center mt-4 py-3 bg-dark text-white">
        <div class="container">
            <span>Thanks for visiting my Favorite Movies page! 🎬</span>
        </div>
    </footer>

    
    <script src="bootstrap-4.1.3-dist/js/bootstrap.min.js"></script>
    
    <script src="fontawesome-free-5.5.0-web/js/all.min.js"></script>
</body>
</html>